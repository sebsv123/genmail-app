# ═══════════════════════════════════════════════════════════════════════════════
# GenMail Production Environment Variables
# Copy this file to .env.production and fill in all values before deploying
# ═══════════════════════════════════════════════════════════════════════════════

# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
# PostgreSQL connection string with SSL for production
DATABASE_URL=postgresql://user:pass@your-db-host:5432/genmail?sslmode=require

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Redis connection string with authentication
REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# ── NEXTAUTH ────────────────────────────────────────────────────────────────────
# Full URL of your deployed Next.js app
NEXTAUTH_URL=https://app.genmail.app

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-characters-long-here

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── EMAIL ──────────────────────────────────────────────────────────────────────
# Resend API key for magic links
RESEND_API_KEY=re_your-resend-api-key

# From address for all emails
EMAIL_FROM=noreply@genmail.app

# ── LISTMONK ────────────────────────────────────────────────────────────────────
# Listmonk API base URL (your email service)
LISTMONK_BASE_URL=https://mail.genmail.app/api

# Listmonk admin credentials
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=your-secure-listmonk-password

# Webhook secret for verification (generate random string)
LISTMONK_WEBHOOK_SECRET=your-random-webhook-secret-for-verification

# ── IA SERVICE ─────────────────────────────────────────────────────────────────
# OpenAI API key for email generation
OPENAI_API_KEY=sk-your-openai-api-key

# URL of deployed AI service (internal Docker network or external)
AI_SERVICE_URL=https://ai.genmail.app

# ── LEAD HUNTER ─────────────────────────────────────────────────────────────────
# Apollo.io API key (optional - falls back to mock mode if not set)
APOLLO_API_KEY=your-apollo-api-key

# Hunter.io API key (optional - falls back to mock mode if not set)
HUNTER_API_KEY=your-hunter-api-key

# Google Places API key (optional - falls back to mock mode if not set)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── APP CONFIG ───────────────────────────────────────────────────────────────────
# Public URL for frontend
NEXT_PUBLIC_APP_URL=https://app.genmail.app

# Node environment (always production for deployed instances)
NODE_ENV=production

# ── OPTIONAL: MONITORING ────────────────────────────────────────────────────────
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Log level (debug, info, warn, error)
LOG_LEVEL=info
