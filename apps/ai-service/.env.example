# FASE 17: Embedding Mode
# "local" uses BGE-M3 (free, 1024 dimensions, ~1.2GB RAM)
# "openai" uses OpenAI API (paid, 1536 dimensions)
EMBEDDING_MODE=local

# Required for openai mode (if EMBEDDING_MODE=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Redis (for embedding cache in FASE 17F)
REDIS_URL=redis://localhost:6379

# Other AI Service settings
LOG_LEVEL=INFO
