{
  "name": "@genmail/ai-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn src.main:app --reload --port 8000",
    "start": "python -m uvicorn src.main:app --host 0.0.0.0 --port 8000",
    "test": "pytest tests/ -v",
    "test:cov": "pytest tests/ -v --cov=src",
    "lint": "ruff check src/",
    "lint:fix": "ruff check src/ --fix",
    "typecheck": "mypy src/"
  }
}
