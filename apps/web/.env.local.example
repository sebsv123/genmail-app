# Local Development Environment Variables
# Copy to .env.local and fill in with your local/dev values

# Database (use local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genmail

# Redis (use local Redis)
REDIS_URL=redis://localhost:6379/0

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-development-secret-at-least-32-characters-long

# Google OAuth (create credentials at console.cloud.google.com)
# For local dev, use http://localhost:3000 as authorized redirect URI
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend - get free API key at resend.com)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@genmail.app

# Listmonk (local instance)
LISTMONK_BASE_URL=http://localhost:9000/api
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=admin
LISTMONK_WEBHOOK_SECRET=local-webhook-secret

# AI Service (local FastAPI instance)
OPENAI_API_KEY=sk-your-openai-api-key
AI_SERVICE_URL=http://localhost:8000

# Lead Hunter (optional - mock mode works without these)
APOLLO_API_KEY=
HUNTER_API_KEY=
GOOGLE_PLACES_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
