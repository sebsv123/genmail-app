{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=web",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXTAUTH_URL": "@nextauth-url",
    "NEXTAUTH_SECRET": "@nextauth-secret",
    "DATABASE_URL": "@database-url",
    "REDIS_URL": "@redis-url",
    "GOOGLE_CLIENT_ID": "@google-client-id",
    "GOOGLE_CLIENT_SECRET": "@google-client-secret",
    "RESEND_API_KEY": "@resend-api-key",
    "EMAIL_FROM": "@email-from",
    "LISTMONK_BASE_URL": "@listmonk-base-url",
    "LISTMONK_USERNAME": "@listmonk-username",
    "LISTMONK_PASSWORD": "@listmonk-password",
    "LISTMONK_WEBHOOK_SECRET": "@listmonk-webhook-secret",
    "AI_SERVICE_URL": "@ai-service-url",
    "NEXT_PUBLIC_APP_URL": "@next-public-app-url"
  },
  "github": {
    "enabled": false
  },
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  }
}
