generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  OWNER
  MEMBER
}

enum UserPlan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum PatternType {
  SUBJECT_LINE
  COPY_FRAMEWORK
  EMAIL_LENGTH
  SEND_TIME
  HOOK_TYPE
  CTA_TYPE
}

enum LearningEventType {
  EMAIL_SENT
  OPENED
  CLICKED
  REPLIED
  CONVERTED
  REJECTED_BY_HUMAN
}

enum ABTestStatus {
  RUNNING
  COMPLETED
  STOPPED
}

enum ABTestType {
  SUBJECT_LINE
  COPY_FRAMEWORK
  EMAIL_LENGTH
  CTA_TYPE
  SEND_TIME
}

enum SectorVocabularyType {
  PREFERRED
  PROHIBITED
  POWER_WORDS
  WEAK_WORDS
}

enum SectorInsightType {
  PAIN_POINT
  OBJECTION
  TRIGGER
  BUYING_SIGNAL
  TRUST_FACTOR
}

enum LeadStage {
  NEW
  NURTURING
  QUALIFIED
  CONVERTED
  UNSUBSCRIBED
}

enum SequenceMode {
  EVERGREEN
  NURTURING_INFINITE
  COLD_OUTREACH
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum GeneratedEmailStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SENT
  REJECTED
}

enum ProspectStatus {
  FOUND
  VALIDATED
  APPROVED
  ENROLLED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

enum ProspectSource {
  LINKEDIN
  GOOGLE_MAPS
  APOLLO
  HUNTER
  DIRECTORY
  MANUAL
}

enum KnowledgeSourceType {
  RSS
  URL
  DOCUMENT
  SAMPLE_EMAIL
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum AnalyticsEventType {
  SENT
  OPENED
  CLICKED
  REPLIED
  UNSUBSCRIBED
  BOUNCED
}

// ==================== MODELS ====================

model Business {
  id               String   @id @default(uuid())
  name             String
  sector           String
  brandVoice       String?  @db.Text
  prohibitedClaims String[]
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  users               User[]
  leads               Lead[]
  sequences           Sequence[]
  knowledgeSources    KnowledgeSource[]
  icps                ICP[]
  prospects           Prospect[]
  subscription        Subscription?
  usageRecords        UsageRecord[]
  embeddingChunks     EmbeddingChunk[]
  performancePatterns PerformancePattern[]
  learningEvents      LearningEvent[]
  notifications       Notification[]
  ABTest              ABTest[]
  generatedEmails     GeneratedEmail[]

  @@index([name])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String?
  emailVerified       DateTime?
  image               String?
  role                UserRole
  plan                UserPlan  @default(FREE)
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]
  notifications Notification[]

  @@index([businessId])
  @@index([email])
}

// ==================== NEXTAUTH MODELS ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id              String    @id @default(uuid())
  email           String
  name            String
  phone           String?
  contextData     Json?
  stage           LeadStage @default(NEW)
  intentScore     Float?
  unsubscribedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  enrollments     SequenceEnrollment[]
  generatedEmails GeneratedEmail[]
  analytics       AnalyticsEvent[]
  memory          LeadMemory?
  embedding       LeadEmbedding?
  externalSignals ExternalSignal[]

  @@unique([businessId, email])
  @@index([businessId, stage])
  @@index([businessId])
}

model Sequence {
  id        String         @id @default(uuid())
  name      String
  mode      SequenceMode
  status    SequenceStatus @default(DRAFT)
  goal      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  templates   EmailTemplate[]
  enrollments SequenceEnrollment[]
  ABTest      ABTest[]

  @@index([businessId, status])
  @@index([businessId])
}

model SequenceEnrollment {
  id          String           @id @default(uuid())
  currentStep Int              @default(0)
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  // Relations
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  generatedEmails GeneratedEmail[]

  @@unique([leadId, sequenceId])
  @@index([leadId])
  @@index([sequenceId])
}

model EmailTemplate {
  id            String   @id @default(uuid())
  stepNumber    Int
  subject       String
  bodyHtml      String   @db.Text
  bodyText      String   @db.Text
  copyFramework String // AIDA, PAS, BAB, etc.
  goal          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  generatedEmails GeneratedEmail[]

  @@index([sequenceId, stepNumber])
  @@index([sequenceId])
}

model GeneratedEmail {
  id               String               @id @default(uuid())
  businessId       String
  subject          String
  previewText      String?
  bodyHtml         String               @db.Text
  bodyText         String               @db.Text
  status           GeneratedEmailStatus @default(DRAFT)
  qualityScore     Float?
  qualityRationale String?
  usedSources      Json?
  metadata         Json?
  generatedAt      DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sentAt           DateTime?

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  enrollmentId String
  enrollment   SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  analytics     AnalyticsEvent[]
  LearningEvent LearningEvent[]
  ABVariant     ABVariant?       @relation(fields: [aBVariantId], references: [id])
  aBVariantId   String?

  @@index([businessId, status])
  @@index([leadId, status])
  @@index([leadId])
  @@index([enrollmentId])
  @@index([templateId])
}

model LeadMemory {
  id             String    @id @default(uuid())
  topicsUsed     String[]
  hooksUsed      String[]
  ctasUsed       String[]
  claimsMade     String[]
  lastEngagement DateTime?
  updatedAt      DateTime  @updatedAt

  // Learning fields
  bestSendTime        String?
  bestFramework       String?
  bestHookType        String?
  avgResponseDelay    Float?
  totalEmailsReceived Int     @default(0)
  totalOpened         Int     @default(0)
  totalClicked        Int     @default(0)
  totalReplied        Int     @default(0)
  personalOpenRate    Float?
  personalClickRate   Float?

  // Relations
  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model KnowledgeSource {
  id           String                       @id @default(uuid())
  type         KnowledgeSourceType
  name         String
  url          String?
  content      String?                      @db.Text
  embedding    Unsupported("vector(1024)")?
  status       KnowledgeSourceStatus        @default(PENDING)
  metadata     Json?
  lastSyncedAt DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([businessId])
}

model AnalyticsEvent {
  id         String             @id @default(uuid())
  type       AnalyticsEventType
  metadata   Json?
  occurredAt DateTime           @default(now())

  // Relations
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  generatedEmailId String?
  generatedEmail   GeneratedEmail? @relation(fields: [generatedEmailId], references: [id], onDelete: Cascade)

  @@index([leadId, type])
  @@index([leadId])
  @@index([generatedEmailId])
  @@index([occurredAt])
}

// ==================== LEAD HUNTER: ICP (Ideal Customer Profile) ====================

model ICP {
  id          String   @id @default(uuid())
  sector      String
  targetRole  String
  companySize String?
  painPoints  String[]
  location    String?
  keywords    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  prospects  Prospect[]

  @@index([businessId])
  @@index([businessId, isActive])
}

// ==================== LEAD HUNTER: Prospect ====================

model Subscription {
  id                   String             @id @default(uuid())
  businessId           String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 UserPlan
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([stripeCustomerId])
  @@index([status])
}

model UsageRecord {
  id          String   @id @default(uuid())
  businessId  String
  month       String // "2026-04"
  emailsSent  Int      @default(0)
  leadsHunted Int      @default(0)
  activeLeads Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, month])
  @@index([businessId])
  @@index([month])
}

model Prospect {
  id             String         @id @default(uuid())
  email          String
  firstName      String?
  lastName       String?
  companyName    String?
  companyWebsite String?
  role           String?
  phone          String?
  source         ProspectSource
  sourceUrl      String?
  status         ProspectStatus @default(FOUND)
  intentScore    Float?
  enrichmentData Json?
  emailVerified  Boolean        @default(false)
  approvedAt     DateTime?
  enrolledAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  icpId String
  icp   ICP    @relation(fields: [icpId], references: [id], onDelete: Cascade)

  coldEmails      ColdEmail[]
  externalSignals ExternalSignal[]

  @@unique([businessId, email])
  @@index([businessId, status])
  @@index([icpId])
}

// ==================== LEAD HUNTER: Cold Email ====================

enum ColdEmailStatus {
  DRAFT
  SCHEDULED
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
}

model ColdEmail {
  id          String          @id @default(uuid())
  stepNumber  Int
  subject     String
  bodyHtml    String          @db.Text
  bodyText    String          @db.Text
  status      ColdEmailStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  openedAt    DateTime?
  repliedAt   DateTime?
  generatedAt DateTime        @default(now())

  // Relations
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
}

// ==================== RAG: Embeddings ====================

model EmbeddingChunk {
  id          String                      @id @default(uuid())
  businessId  String
  sourceId    String
  content     String                      @db.Text
  contentHash String
  embedding   Unsupported("vector(1024)")
  metadata    Json                        @default("{}")
  createdAt   DateTime                    @default(now())

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, contentHash])
  @@index([businessId])
}

model LeadEmbedding {
  id             String                      @id @default(uuid())
  leadId         String                      @unique
  profileSummary String                      @db.Text
  embedding      Unsupported("vector(1024)")
  updatedAt      DateTime                    @updatedAt

  // Relations
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ==================== Learning Models ====================

model PerformancePattern {
  id              String      @id @default(uuid())
  businessId      String
  patternType     PatternType
  patternValue    String
  sector          String?
  sampleSize      Int         @default(0)
  openRate        Float       @default(0)
  clickRate       Float       @default(0)
  replyRate       Float       @default(0)
  conversionRate  Float       @default(0)
  confidenceScore Float       @default(0)
  lastUpdated     DateTime    @updatedAt
  createdAt       DateTime    @default(now())

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, patternType, patternValue])
  @@index([businessId])
  @@index([businessId, patternType])
}

model LearningEvent {
  id               String            @id @default(uuid())
  businessId       String
  generatedEmailId String?
  eventType        LearningEventType
  signals          Json              @default("{}")
  processedAt      DateTime?
  createdAt        DateTime          @default(now())

  // Relations
  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email    GeneratedEmail? @relation(fields: [generatedEmailId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, eventType])
  @@index([generatedEmailId])
  @@index([createdAt])
}

model Notification {
  id         String   @id @default(uuid())
  businessId String
  userId     String?
  type       String
  title      String
  body       String
  read       Boolean  @default(false)
  actionUrl  String?
  createdAt  DateTime @default(now())

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, read])
  @@index([userId])
  @@index([createdAt])
}

model SectorBenchmark {
  id             String   @id @default(uuid())
  sector         String
  avgOpenRate    Float
  avgClickRate   Float
  avgReplyRate   Float
  bestDayOfWeek  String
  bestHourRange  String
  avgEmailLength String
  bestFrameworks String[]
  source         String
  updatedAt      DateTime @updatedAt

  @@unique([sector])
  @@index([sector])
}

model SectorVocabulary {
  id        String               @id @default(uuid())
  sector    String
  type      SectorVocabularyType
  words     String[]
  reason    String
  updatedAt DateTime             @updatedAt

  @@index([sector, type])
}

model SectorTemplate {
  id            String       @id @default(uuid())
  sector        String
  name          String
  sequenceMode  SequenceMode
  stepNumber    Int
  goal          String
  subject       String
  bodyText      String
  copyFramework String
  qualityScore  Float
  usageCount    Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  @@index([sector, sequenceMode])
  @@index([qualityScore])
}

model SectorInsight {
  id          String            @id @default(uuid())
  sector      String
  insightType SectorInsightType
  title       String
  description String
  examples    String[]
  weight      Float
  createdAt   DateTime          @default(now())

  @@index([sector, insightType])
}

model ABTest {
  id                  String       @id @default(uuid())
  businessId          String
  sequenceId          String?
  name                String
  status              ABTestStatus @default(RUNNING)
  testType            ABTestType
  startedAt           DateTime     @default(now())
  completedAt         DateTime?
  winnerVariantId     String?
  minSampleSize       Int          @default(50)
  confidenceThreshold Float        @default(0.95)
  createdAt           DateTime     @default(now())

  // Relations
  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sequence Sequence?   @relation(fields: [sequenceId], references: [id], onDelete: SetNull)
  variants ABVariant[]

  @@index([businessId, status])
  @@index([sequenceId])
}

model ABVariant {
  id             String   @id @default(uuid())
  testId         String
  name           String
  subject        String
  bodyHtml       String
  bodyText       String
  copyFramework  String
  hypothesis     String
  sent           Int      @default(0)
  opened         Int      @default(0)
  clicked        Int      @default(0)
  replied        Int      @default(0)
  openRate       Float    @default(0)
  clickRate      Float    @default(0)
  replyRate      Float    @default(0)
  compositeScore Float    @default(0)
  createdAt      DateTime @default(now())

  // Relations
  test           ABTest           @relation(fields: [testId], references: [id], onDelete: Cascade)
  generatedEmail GeneratedEmail[]

  @@index([testId])
}

// ==================== EXTERNAL SIGNALS (FASE 18) ====================

enum ExternalSignalType {
  GOOGLE_TREND_SPIKE
  COMPANY_HIRING
  COMPANY_GREW
  JOB_CHANGE
  FUNDING_ROUND
  SECTOR_NEWS
  COMPETITOR_MENTIONED
  PRICE_SEARCH
  WEBSITE_VISIT
}

model ExternalSignal {
  id          String             @id @default(uuid())
  signalType  ExternalSignalType
  source      String
  data        Json               @default("{}")
  intentBoost Float              @default(0)
  detectedAt  DateTime           @default(now())
  processedAt DateTime?

  // Optional relations (one of these should be set)
  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  prospectId String?
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([leadId, detectedAt])
  @@index([prospectId, detectedAt])
  @@index([signalType, detectedAt])
}

model SectorTrend {
  id           String   @id @default(uuid())
  sector       String
  keyword      String
  trendScore   Float
  weeklyChange Float
  region       String   @default("ES")
  recordedAt   DateTime @default(now())

  @@unique([sector, keyword, recordedAt])
  @@index([sector, recordedAt])
  @@index([keyword, region])
}
